# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Your deployed frontend URL (e.g. https://saffron.vercel.app)
# On Railway: set this in Variables tab after deploying frontend
FRONTEND_URL=http://localhost:3000

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# OPTION A — Railway MySQL plugin (copy the MYSQL_URL from Railway Variables tab)
# MYSQL_URL=mysql://root:password@containers-us-west-xxx.railway.app:6543/railway

# OPTION B — Local development (used if MYSQL_URL is not set)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=saffron_catering

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_characters
JWT_EXPIRES_IN=7d

# ─── EMAIL (Gmail) ────────────────────────────────────────────────────────────
# Enable 2FA on Gmail → Google Account → Security → App Passwords → generate one
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=Saffron Catering <your_gmail@gmail.com>
